# =============================================================================
# bitza — frontend/bitza/.gitignore
#
# Angular / Node specific rules only. Cross-cutting rules (editors, IDEs,
# OS artefacts) live in the root .gitignore and already apply here too —
# no need to repeat them. This file replaces the Angular-CLI-generated
# .gitignore that used to live here; a few entries from that scaffold
# (Bazel, Testem/Karma, the old `typings` tool, `connect.lock`) were
# dropped as dead weight from tooling this project doesn't use.
# =============================================================================


# -----------------------------------------------------------------------------
# Compiled output
# -----------------------------------------------------------------------------
/dist
/out-tsc
/tmp


# -----------------------------------------------------------------------------
# Node
# package-lock.json and yarn.lock are intentionally NOT listed here.
# This is an application, not a published library — the lockfile must be
# committed so every install (yours, CI, a teammate's) resolves the exact
# same dependency tree. Please don't re-add it without a specific reason.
# -----------------------------------------------------------------------------
/node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*


# -----------------------------------------------------------------------------
# Angular
# -----------------------------------------------------------------------------
/.angular/
*.tsbuildinfo
/coverage
e2e/test-output/


# -----------------------------------------------------------------------------
# Sass
# -----------------------------------------------------------------------------
.sass-cache/


# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
__screenshots__/
