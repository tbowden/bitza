# .env.dev — Development environment
# Copy to .env.dev and customise. Never commit real secrets.

APP_ENV=dev
DEBUG=true
APP_NAME=Bitza asset management API (dev)

# SQLite DB file for dev
DATABASE_URL=sqlite:///./data/dev.db

# Generate a real key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-insecure-secret-key-replace-me

ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Password breach checking (requires public internet access)
CHECK_PWNED_PASSWORDS=false
