# .env.test — Test environment
# Used automatically when APP_ENV=test (set by pytest.ini)

APP_ENV=test
DEBUG=false
APP_NAME=Bitza asset management API (test)

# Tests use an in-memory SQLite database — override in conftest.py via
# dependency injection, not from this file.
DATABASE_URL=sqlite:///./data/test.db

SECRET_KEY=test-secret-key-not-for-production

ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Password breach checking (requires public internet access)
CHECK_PWNED_PASSWORDS=false
