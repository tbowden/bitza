# .env.prod — Production environment
# This file MUST be created on the server — do NOT commit it to source control.
# Add .env.prod to .gitignore.

APP_ENV=prod
DEBUG=false
APP_NAME=Bitza asset management API

# Mounted as a Docker volume: ./data/prod.db → /app/data/prod.db
DATABASE_URL=sqlite:///./data/prod.db

# REQUIRED: generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_REAL_PRODUCTION_SECRET_MINIMUM_32_CHARS

ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
CHECK_PWNED_PASSWORDS=true
