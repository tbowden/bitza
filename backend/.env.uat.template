# .env.uat — UAT / staging environment

APP_ENV=uat
DEBUG=false
APP_NAME=Bitza asset management API (uat)

DATABASE_URL=sqlite:///./data/uat.db

# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_REAL_UAT_SECRET

ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Password breach checking (requires public internet access)
CHECK_PWNED_PASSWORDS=false
